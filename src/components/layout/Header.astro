---
import { navigation, contactInfo } from '@/data/stats';
---

<header id="header" class="fixed top-0 left-0 w-full z-50">
  <!-- Transparent by default, solid on scroll -->
  <div class="header-bg transition-all duration-400">
    <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="header-inner flex items-center justify-between">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-2.5 shrink-0 group">
          <img src="/images/logo-th.png" alt="Трак Холдинг" class="h-6 lg:h-7 w-auto transition-opacity duration-300 group-hover:opacity-80" />
          <span class="hidden sm:block text-white font-heading font-bold text-[13px] lg:text-sm tracking-[0.15em] uppercase">ТРАК ХОЛДИНГ</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-1">
          {navigation.map((link) => (
            <a
              href={link.href}
              class="nav-link relative text-white/70 hover:text-white text-[13px] font-medium uppercase tracking-[0.08em] px-4 py-2 transition-all duration-300"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Phone + CTA -->
        <div class="hidden lg:flex items-center gap-5">
          <a
            href={`tel:${contactInfo.phone.replace(/[\s()-]/g, '')}`}
            class="text-white/60 hover:text-white text-sm font-medium tracking-wide transition-colors"
          >
            {contactInfo.phone}
          </a>
          <a
            href="#contact"
            class="cta-glow bg-accent hover:bg-accent-hover text-white text-[13px] font-heading font-semibold uppercase tracking-wider px-6 py-2.5 rounded-md transition-all duration-300 hover:translate-y-[-1px]"
          >
            Оставить заявку
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="menu-toggle"
          class="lg:hidden flex flex-col gap-1.5 p-2"
          aria-label="Открыть меню"
        >
          <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar1"></span>
          <span class="w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
          <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar3"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-dark/95 backdrop-blur-xl border-b border-white/5">
    <div class="max-w-[var(--container-max-width)] mx-auto px-4 py-6 space-y-1">
      {navigation.map((link) => (
        <a
          href={link.href}
          class="mobile-link block text-white/70 hover:text-white hover:bg-white/5 text-lg font-heading uppercase tracking-wider py-3 px-4 rounded-lg transition-all"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 mt-4 border-t border-white/5 space-y-3">
        <a href={`tel:${contactInfo.phone.replace(/[\s()-]/g, '')}`} class="block text-white text-lg px-4">
          {contactInfo.phone}
        </a>
        <a
          href="#contact"
          class="mobile-link block text-center cta-glow bg-accent hover:bg-accent-hover text-white font-heading font-semibold uppercase tracking-wider px-5 py-3.5 rounded-lg transition-all"
        >
          Оставить заявку
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  /* Initially transparent */
  .header-bg {
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  /* Solid on scroll — class added by JS */
  #header.scrolled .header-bg {
    background: rgba(10, 10, 13, 0.92);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Nav link hover underline */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: 60%;
  }

  /* Active nav link */
  .nav-link.active {
    color: var(--color-white);
  }

  .nav-link.active::after {
    width: 60%;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  const header = document.getElementById('header');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('hidden', !open);
    bar1!.style.transform = open ? 'rotate(45deg) translate(3px, 3px)' : '';
    bar2!.style.opacity = open ? '0' : '1';
    bar3!.style.transform = open ? 'rotate(-45deg) translate(3px, -3px)' : '';
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      menu?.classList.add('hidden');
      bar1!.style.transform = '';
      bar2!.style.opacity = '1';
      bar3!.style.transform = '';
    });
  });

  // Transparent → solid header on scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Active nav link on scroll
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  const observerNav = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, { rootMargin: '-40% 0px -60% 0px' });

  sections.forEach(s => observerNav.observe(s));
</script>
