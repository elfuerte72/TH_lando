---
import { navigation, contactInfo } from '@/data/stats';
---

<header id="header" class="fixed top-0 left-0 w-full z-50">
  <!-- Transparent by default, solid on scroll -->
  <div class="header-bg transition-all duration-400">
    <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="header-inner flex items-center justify-between">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-2.5 shrink-0 group">
          <img src="/images/logo-th.png" alt="Трак Холдинг" class="h-6 lg:h-7 w-auto transition-opacity duration-300 group-hover:opacity-80" />
          <span class="text-white font-heading font-bold text-[13px] lg:text-sm tracking-[0.15em] uppercase">ТРАК ХОЛДИНГ</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-1">
          {navigation.map((link) => (
            <a
              href={link.href}
              class="nav-link relative text-white/70 hover:text-white text-[13px] font-medium uppercase tracking-[0.08em] px-4 py-2 transition-all duration-300"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Phone + CTA -->
        <div class="hidden lg:flex items-center gap-2">
          <a href={contactInfo.max} target="_blank" rel="noopener noreferrer" class="inline-flex shrink-0 hover:opacity-80 transition-opacity" title="Написать в MAX">
            <img src="/images/max-logo.webp" alt="MAX" class="w-5 h-5 rounded" />
          </a>
          <a
            href={contactInfo.max}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/60 hover:text-white text-sm font-medium tracking-wide transition-colors"
          >
            {contactInfo.phone}
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="menu-toggle"
          class="lg:hidden flex items-center justify-center w-11 h-11 -mr-2"
          aria-label="Открыть меню"
          aria-expanded="false"
        >
          <!-- Hamburger icon -->
          <svg id="icon-hamburger" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon (hidden by default) -->
          <svg id="icon-close" class="w-6 h-6 text-accent hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-dark/95 backdrop-blur-xl border-b border-white/5">
    <div class="max-w-[var(--container-max-width)] mx-auto px-4 py-6 space-y-1">
      {navigation.map((link) => (
        <a
          href={link.href}
          class="mobile-link block text-white/70 hover:text-white hover:bg-white/5 text-lg font-heading uppercase tracking-wider py-3 px-4 rounded-lg transition-all"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 mt-4 border-t border-white/5 space-y-3">
        <div class="flex items-center gap-3 px-4">
          <a href={contactInfo.max} target="_blank" rel="noopener noreferrer" class="inline-flex shrink-0 hover:opacity-80 transition-opacity" title="Написать в MAX">
            <img src="/images/max-logo.webp" alt="MAX" class="w-6 h-6 rounded" />
          </a>
          <a href={contactInfo.max} target="_blank" rel="noopener noreferrer" class="text-white text-lg">
            {contactInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  /* Initially transparent */
  .header-bg {
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  /* Solid on scroll — class added by JS */
  #header.scrolled .header-bg {
    background: rgba(10, 10, 13, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Nav link hover underline */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: 60%;
  }

  /* Active nav link */
  .nav-link.active {
    color: var(--color-white);
  }

  .nav-link.active::after {
    width: 60%;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconHamburger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');
  const header = document.getElementById('header');
  let open = false;

  function updateMenuIcon() {
    iconHamburger?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  }

  function closeMenu() {
    open = false;
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    updateMenuIcon();
  }

  toggle?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    updateMenuIcon();
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) closeMenu();
  });

  // Transparent → solid header on scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // Active nav link on scroll
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  const observerNav = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, { rootMargin: '-40% 0px -60% 0px' });

  sections.forEach(s => observerNav.observe(s));
</script>
