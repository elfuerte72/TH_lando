---
import { advantages } from '@/data/stats';
---

<section id="advantages" class="relative py-24 lg:py-36 overflow-hidden">

  <!-- LAYER 1: Background photo with vignette -->
  <div class="absolute inset-0">
    <img
      src="/images/advantages/team-bg.png"
      alt=""
      loading="lazy"
      class="advantages-bg w-full h-full object-cover"
      style="object-position: 50% 40%;"
    />

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-dark/65"></div>

    <!-- Edge feathers: seamless blend into #0a0a0d -->
    <div class="absolute inset-x-0 top-0 h-24 lg:h-48 bg-gradient-to-b from-dark to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-24 lg:h-48 bg-gradient-to-t from-dark to-transparent"></div>
    <div class="absolute inset-y-0 left-0 w-16 lg:w-40 bg-gradient-to-r from-dark to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-16 lg:w-40 bg-gradient-to-l from-dark to-transparent"></div>
  </div>

  <!-- LAYER 2: Content -->
  <div class="relative z-10 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-14 lg:mb-20 advantages-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        Преимущества
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ПОЧЕМУ <span class="text-accent">ТРАК ХОЛДИНГ</span></span>
        </span>
      </h2>
    </div>

    <!-- Advantages List -->
    <div class="advantages-list max-w-3xl">
      {advantages.map((advantage) => (
        <div class="advantage-item overflow-hidden py-5">
          <span class="advantage-text inline-block text-white/90 text-lg lg:text-xl font-medium tracking-wide">{advantage}</span>
          <div class="advantage-line mt-3 h-px w-0 bg-gradient-to-r from-accent via-accent/40 to-transparent"></div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Elliptical vignette mask on background photo */
  .advantages-bg {
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    will-change: transform;
  }

</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── 1. Subtle background parallax ──
  const bgEl = document.querySelector('.advantages-bg');
  if (bgEl) {
    gsap.to(bgEl, {
      scrollTrigger: {
        trigger: '#advantages',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 0.8,
      },
      y: -60,
      ease: 'none',
    });
  }

  // ── 2. Header reveal ──
  const header = document.querySelector('.advantages-header');
  if (header) {
    gsap.from(header, {
      scrollTrigger: {
        trigger: '#advantages',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
    });
  }

  // ── 3. Advantages list: text slides from left + line sweep ──
  const advItems = document.querySelectorAll('.advantage-item');
  if (advItems.length) {
    advItems.forEach((item, i) => {
      const text = item.querySelector('span');
      const line = item.querySelector('.advantage-line');

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: item,
          start: 'top 92%',
          toggleActions: 'play none none none',
        },
      });

      // Text slides in from left
      if (text) {
        tl.from(text, {
          x: -40,
          opacity: 0,
          duration: 0.6,
          ease: 'power3.out',
          delay: i * 0.12,
        });
      }

      // Line sweeps in from left
      if (line) {
        tl.to(line, {
          width: '100%',
          duration: 0.7,
          ease: 'power2.out',
        }, '-=0.2');
      }
    });
  }
</script>
