---
import { stats, advantages } from '@/data/stats';

const iconPaths: Record<string, string> = {
  calendar: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  truck: 'M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2-1 2 1 2-1 2 1zm0 0l2-1 2 1 2-1 2 1V6a1 1 0 00-1-1h-2a1 1 0 00-1 1v10',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  satellite: 'M9.348 14.651a3.75 3.75 0 010-5.303m5.304 0a3.75 3.75 0 010 5.303m-7.425 2.122a6.75 6.75 0 010-9.546m9.546 0a6.75 6.75 0 010 9.546M5.106 18.894c-3.808-3.808-3.808-9.98 0-13.789m13.788 0c3.808 3.808 3.808 9.981 0 13.79M12 12h.008v.007H12V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z',
};

// Classify stat values for counter animation
const statMeta = stats.map((stat) => {
  const numMatch = stat.value.match(/^(\d+)/);
  return {
    ...stat,
    isNumeric: !!numMatch,
    numericTarget: numMatch ? parseInt(numMatch[1]) : 0,
    suffix: numMatch ? stat.value.replace(numMatch[1], '') : '',
  };
});
---

<section id="advantages" class="relative py-24 lg:py-36 overflow-hidden">

  <!-- LAYER 1: Background photo with vignette -->
  <div class="absolute inset-0">
    <img
      src="/images/advantages/team-bg.png"
      alt=""
      loading="lazy"
      class="advantages-bg w-full h-full object-cover"
      style="object-position: 50% 40%;"
    />

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-dark/65"></div>

    <!-- Edge feathers: seamless blend into #0a0a0d -->
    <div class="absolute inset-x-0 top-0 h-24 lg:h-48 bg-gradient-to-b from-dark to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-24 lg:h-48 bg-gradient-to-t from-dark to-transparent"></div>
    <div class="absolute inset-y-0 left-0 w-16 lg:w-40 bg-gradient-to-r from-dark to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-16 lg:w-40 bg-gradient-to-l from-dark to-transparent"></div>
  </div>

  <!-- LAYER 2: Content -->
  <div class="relative z-10 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-14 lg:mb-20 advantages-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        Преимущества
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ПОЧЕМУ <span class="text-accent">ТРАК ХОЛДИНГ</span></span>
        </span>
      </h2>
    </div>

    <!-- Stats Row -->
    <div id="stats-row" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6 mb-14 lg:mb-20">
      {statMeta.map((stat, i) => (
        <div class="stat-item text-center p-5 lg:p-7 rounded-2xl bg-dark/40 backdrop-blur-sm border border-white/[0.06] hover:border-accent/20 transition-all duration-300">
          <!-- Icon -->
          <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[stat.icon] || iconPaths.truck} />
            </svg>
          </div>
          <!-- Value -->
          <div
            class="stat-value font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black text-white mb-2 leading-none"
            data-value={stat.value}
            data-target={stat.isNumeric ? String(stat.numericTarget) : ''}
            data-suffix={stat.suffix}
          >
            <span class="stat-display">{stat.isNumeric ? '0' : stat.value}</span>
          </div>
          <!-- Label -->
          <div class="text-gray-sub text-xs sm:text-sm lg:text-base tracking-wide leading-snug">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Advantages List -->
    <div class="advantages-list grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-4">
      {advantages.map((advantage) => (
        <div class="advantage-item flex items-start gap-3 p-4 rounded-xl bg-dark/40 backdrop-blur-sm border border-white/[0.06]">
          <div class="flex-shrink-0 w-7 h-7 bg-accent/10 rounded-lg flex items-center justify-center mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-white/90 text-base lg:text-lg leading-relaxed">{advantage}</span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Elliptical vignette mask on background photo */
  .advantages-bg {
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    will-change: transform;
  }

  /* Accent glow on stat values after counter animation */
  .stat-value.counted {
    color: var(--color-accent);
    text-shadow:
      0 0 20px rgba(29, 122, 204, 0.4),
      0 0 60px rgba(29, 122, 204, 0.12);
    transition: text-shadow 0.6s ease, color 0.6s ease;
  }

  /* Accent underline that reveals after stat animation */
  .stat-item {
    position: relative;
  }

  .stat-item::after {
    content: '';
    display: block;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    margin: 12px auto 0;
    border-radius: 1px;
    transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .stat-item.revealed::after {
    width: 40px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── 1. Subtle background parallax ──
  const bgEl = document.querySelector('.advantages-bg');
  if (bgEl) {
    gsap.to(bgEl, {
      scrollTrigger: {
        trigger: '#advantages',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 0.8,
      },
      y: -60,
      ease: 'none',
    });
  }

  // ── 2. Header reveal ──
  const header = document.querySelector('.advantages-header');
  if (header) {
    gsap.from(header, {
      scrollTrigger: {
        trigger: '#advantages',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
    });
  }

  // ── 3. Stat cards staggered entrance ──
  const statItems = document.querySelectorAll('.stat-item');
  if (statItems.length) {
    gsap.from(statItems, {
      scrollTrigger: {
        trigger: '#stats-row',
        start: 'top 85%',
        toggleActions: 'play none none none',
        onEnter: () => {
          setTimeout(startCounters, 400);
        },
      },
      y: 50,
      opacity: 0,
      duration: 0.6,
      stagger: 0.12,
      ease: 'power3.out',
      onComplete: () => {
        statItems.forEach(el => el.classList.add('revealed'));
      },
    });
  }

  // ── 4. Counter animation ──
  function startCounters() {
    document.querySelectorAll('.stat-value').forEach((el) => {
      const htmlEl = el as HTMLElement;
      const raw = htmlEl.dataset.value || '';
      const target = parseInt(htmlEl.dataset.target || '0');
      const suffix = htmlEl.dataset.suffix || '';
      const display = el.querySelector('.stat-display') as HTMLElement;
      if (!display) return;

      if (target > 0) {
        // Numeric counter: animate from 0 to target
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          onUpdate: () => {
            display.textContent = Math.round(obj.val) + suffix;
          },
          onComplete: () => {
            el.classList.add('counted');
          },
        });
      } else {
        // Non-numeric (24/7, I-IV, GPS): scale-up + fade
        gsap.from(display, {
          scale: 0.5,
          opacity: 0,
          duration: 0.8,
          ease: 'back.out(1.7)',
          onComplete: () => {
            el.classList.add('counted');
          },
        });
      }
    });
  }

  // ── 5. Advantages list staggered reveal ──
  const advItems = document.querySelectorAll('.advantage-item');
  if (advItems.length) {
    gsap.from(advItems, {
      scrollTrigger: {
        trigger: '.advantages-list',
        start: 'top 90%',
        toggleActions: 'play none none none',
      },
      y: 20,
      opacity: 0,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power3.out',
    });
  }
</script>
