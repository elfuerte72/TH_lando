---
import { advantages, stats } from '@/data/stats';
---

<section id="advantages" class="relative py-16 lg:py-28 overflow-hidden">

  <!-- LAYER 1: Background photo with vignette -->
  <div class="absolute inset-0">
    <img
      src="/images/advantages/bg-excavator.webp"
      alt=""
      loading="lazy"
      decoding="async"
      class="advantages-bg w-full h-full object-cover"
      style="object-position: 50% 40%;"
    />
    <div class="absolute inset-0 bg-dark/75"></div>
    <div class="absolute inset-x-0 top-0 h-32 lg:h-56 bg-gradient-to-b from-dark to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-32 lg:h-56 bg-gradient-to-t from-dark to-transparent"></div>
    <div class="absolute inset-y-0 left-0 w-24 lg:w-48 bg-gradient-to-r from-dark to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-24 lg:w-48 bg-gradient-to-l from-dark to-transparent"></div>
    <div class="absolute inset-0" style="box-shadow: inset 0 0 100px 50px #0a0a0d;"></div>
  </div>

  <!-- LAYER 2: Content — two columns -->
  <div class="relative z-10 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 lg:mb-16 advantages-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        Преимущества
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ПОЧЕМУ <span class="text-accent">ТРАК ХОЛДИНГ</span></span>
        </span>
      </h2>
    </div>

    <!-- Two-column layout: stats left, advantages right -->
    <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-10 lg:gap-16 items-start">

      <!-- LEFT: Stacked counters -->
      <div class="stats-column flex flex-row flex-wrap lg:flex-col gap-0 order-2 lg:order-1">
        {stats.map((stat, i) => (
          <div
            class="stat-row group flex items-center gap-4 py-4 px-3 lg:px-0 w-1/2 sm:w-1/3 lg:w-full"
            data-index={i}
          >
            <div class="min-w-0">
              <div
                class="stat-value font-heading font-black text-2xl lg:text-3xl text-white leading-none tracking-wide"
                data-value={stat.value}
              >
                {stat.value}
              </div>
              <div class="stat-label text-gray-sub text-[11px] lg:text-xs uppercase tracking-wider mt-0.5 leading-tight">
                {stat.label}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- RIGHT: Advantages list -->
      <div class="advantages-list order-1 lg:order-2">
        {advantages.map((advantage) => (
          <div class="advantage-item overflow-hidden py-5">
            <span class="advantage-text inline-block text-white text-lg lg:text-xl font-bold tracking-wide">{advantage}</span>
            <div class="advantage-line mt-3 h-px w-0 bg-gradient-to-r from-accent via-accent/40 to-transparent"></div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .advantages-bg {
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 85%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 85%);
    filter: saturate(0.3) brightness(0.7);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isDesktop = window.matchMedia('(min-width: 768px)').matches;

  // ── 1. Background parallax (desktop only — causes jank on mobile) ──
  const bgEl = document.querySelector('.advantages-bg');
  if (bgEl && isDesktop) {
    gsap.to(bgEl, {
      scrollTrigger: {
        trigger: '#advantages',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 2,
      },
      y: -40,
      ease: 'none',
    });
  }

  // ── 2. Header reveal ──
  const header = document.querySelector('.advantages-header');
  if (header) {
    gsap.from(header, {
      scrollTrigger: {
        trigger: '#advantages',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
    });
  }

  // ── 3. Stat rows: staggered slide-in + counter ──
  const statRows = document.querySelectorAll('.stat-row');
  statRows.forEach((row, i) => {
    const valueEl = row.querySelector('.stat-value') as HTMLElement;
    const rawValue = valueEl?.dataset.value || '';

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.stats-column',
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.12,
    });

    // Row slides in
    tl.from(row, {
      x: -30,
      opacity: 0,
      duration: 0.5,
      ease: 'power3.out',
    });

    // Counter for numeric values
    if (valueEl) {
      tl.add(() => {
        const numMatch = rawValue.match(/^(\d+)/);
        if (numMatch) {
          const target = parseInt(numMatch[1]);
          const suffix = rawValue.replace(numMatch[1], '');
          const startFrom = target > 100 ? target - 30 : 0;
          gsap.fromTo(
            { val: startFrom },
            {
              val: target,
              duration: target > 100 ? 1.5 : 1,
              ease: 'power2.out',
              snap: { val: 1 },
              onUpdate() {
                valueEl.textContent = String(Math.round(this.targets()[0].val)) + suffix;
              },
            },
          );
        }
      }, '-=0.2');
    }
  });

  // ── 4. Advantages list: text slides from left + line sweep ──
  const advItems = document.querySelectorAll('.advantage-item');
  advItems.forEach((item, i) => {
    const text = item.querySelector('span');
    const line = item.querySelector('.advantage-line');

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: item,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
    });

    if (text) {
      tl.from(text, {
        x: -40,
        opacity: 0,
        duration: 0.6,
        ease: 'power3.out',
        delay: i * 0.12,
      });
    }

    if (line) {
      tl.to(line, {
        width: '100%',
        duration: 0.7,
        ease: 'power2.out',
      }, '-=0.2');
    }
  });
</script>
