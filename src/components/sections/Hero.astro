---
---

<section id="hero" class="relative min-h-[100dvh] min-h-[100vh] flex items-center overflow-hidden">
  <!-- Video Background — poster as CSS bg fallback (avoids iOS native play button) -->
  <div id="hero-bg" class="absolute inset-0 bg-cover bg-center" style="background-image: url('/video/truck-poster.jpg');"></div>

  <!-- Cinematic overlays — strong left side so text always readable -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark/60 via-dark/15 to-dark z-[1]"></div>
  <div class="absolute inset-0 z-[1]" style="background: linear-gradient(to right, rgba(10,10,13,0.85) 0%, rgba(10,10,13,0.55) 45%, transparent 70%);"></div>

  <!-- Content -->
  <div class="hero-content relative z-10 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8 pt-28 lg:pt-32 pb-40 sm:pb-32 lg:pb-36 w-full">
    <div class="max-w-4xl">

      <!-- Main heading — staggered text reveal -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-extrabold leading-[0.9] tracking-tight mb-8" style="text-shadow: 0 2px 30px rgba(0,0,0,0.4);">
        <span class="reveal-line"><span>СИЛА В</span></span>
        <span class="reveal-line"><span class="text-accent">ДВИЖЕНИИ</span></span>
      </h1>

      <!-- Subtitle -->
      <p class="hero-fade hero-fade-2 text-lg sm:text-xl lg:text-2xl max-w-2xl mb-12 leading-relaxed" style="color: #d4d4dc; text-shadow: 0 1px 12px rgba(0,0,0,0.6);">
        Профессиональная транспортировка инертных материалов и&nbsp;отходов бурения на&nbsp;всей территории Сибири.<br class="hidden sm:block" />
        Собственный автопарк самосвалов/шламовозов.
      </p>

      <!-- CTA Buttons -->
      <div class="hero-fade hero-fade-3 flex flex-col sm:flex-row gap-4">
        <a
          href="#fleet"
          class="inline-flex items-center justify-center gap-3 border border-white/15 hover:border-white/30 text-white font-heading font-semibold text-lg uppercase tracking-wider px-10 py-4.5 rounded-lg transition-all duration-300 hover:bg-white/[0.04] backdrop-blur-sm"
        >
          Смотреть автопарк
        </a>
      </div>
    </div>
  </div>

  <!-- Stats row — centered, full width, at the bottom -->
  <div class="hero-fade hero-fade-4 absolute bottom-0 left-0 right-0 z-10">
    <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-8 lg:gap-20 py-6 sm:py-8 border-t border-white/[0.08]">
        <div class="text-center">
          <div class="text-xl sm:text-2xl lg:text-3xl font-heading font-extrabold text-white tracking-tight">2013</div>
          <div class="text-gray-dim text-[10px] sm:text-xs mt-1 tracking-wider uppercase">основание компании</div>
        </div>
        <div class="text-center">
          <div class="text-xl sm:text-2xl lg:text-3xl font-heading font-extrabold text-white tracking-tight">24/7</div>
          <div class="text-gray-dim text-[10px] sm:text-xs mt-1 tracking-wider uppercase">без выходных</div>
        </div>
        <div class="text-center">
          <div class="text-xl sm:text-2xl lg:text-3xl font-heading font-extrabold text-white tracking-tight">6×6</div>
          <div class="text-gray-dim text-[10px] sm:text-xs mt-1 tracking-wider uppercase">полный привод</div>
        </div>
        <div class="text-center">
          <div class="text-xl sm:text-2xl lg:text-3xl font-heading font-extrabold text-accent tracking-tight">III–IV</div>
          <div class="text-gray-dim text-[10px] sm:text-xs mt-1 tracking-wider uppercase">класс опасности</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const isDesktop = window.matchMedia('(min-width: 768px)').matches;

  if (isDesktop) {
    const bg = document.getElementById('hero-bg');
    if (bg) {
      const video = document.createElement('video');
      video.autoplay = true;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.disablePictureInPicture = true;
      video.disableRemotePlayback = true;
      video.preload = 'metadata';
      video.poster = '/video/truck-poster.jpg';
      video.className = 'hero-video absolute inset-0 w-full h-full object-cover';
      bg.appendChild(video);

      // External (Vercel Blob) with local fallback
      const externalSrc = 'https://1kq9ppdwucmvl2un.public.blob.vercel-storage.com/truck-compressed-28.mp4';
      const localSrc = '/video/truck-compressed-28.mp4';

      const source = document.createElement('source');
      source.src = externalSrc;
      source.type = 'video/mp4';
      video.appendChild(source);

      function tryPlay() {
        video.muted = true;
        video.play().catch(() => {});
      }

      video.addEventListener('canplay', tryPlay, { once: true });

      // Fallback: if external video fails to load, try local
      video.addEventListener('error', () => {
        video.src = localSrc;
        video.load();
      }, { once: true });

      source.addEventListener('error', () => {
        video.src = localSrc;
        video.load();
      }, { once: true });

      // Timeout fallback: if video hasn't started in 8s, try local
      const fallbackTimer = setTimeout(() => {
        if (video.readyState < 2) {
          video.src = localSrc;
          video.load();
        }
      }, 8000);

      video.addEventListener('canplay', () => clearTimeout(fallbackTimer), { once: true });

      function onGesture() {
        tryPlay();
        document.removeEventListener('touchstart', onGesture);
        document.removeEventListener('click', onGesture);
        document.removeEventListener('scroll', onGesture);
      }
      document.addEventListener('touchstart', onGesture, { passive: true });
      document.addEventListener('click', onGesture, { once: true });
      document.addEventListener('scroll', onGesture, { passive: true, once: true });
    }
  }
</script>
