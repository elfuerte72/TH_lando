---
import { contactInfo } from '@/data/stats';
import { cargoOptions } from '@/data/materials';
---

<section id="contact" class="py-20 lg:py-30 bg-dark-lighter">
  <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest">Связь</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mt-3 mb-6">ОСТАВИТЬ ЗАЯВКУ</h2>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Рассчитаем стоимость перевозки в&nbsp;течение часа
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Form -->
      <div class="lg:col-span-3">
        <form id="contact-form" class="bg-card border border-white/5 rounded-2xl p-8 lg:p-10 space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-sub mb-2">Имя</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-dark border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-gray-sub/50 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
                placeholder="Ваше имя"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-sub mb-2">Телефон</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full bg-dark border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-gray-sub/50 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
                placeholder="+7 (___) ___-__-__"
              />
            </div>
          </div>

          <div>
            <label for="cargo" class="block text-sm font-medium text-gray-sub mb-2">Что нужно перевезти</label>
            <select
              id="cargo"
              name="cargo"
              class="w-full bg-dark border border-white/10 rounded-xl px-4 py-3.5 text-white focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors appearance-none"
              style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2394A3B8%22 stroke-width=%222%22><path d=%22M6 9l6 6 6-6%22/></svg>'); background-position: right 16px center; background-repeat: no-repeat;"
            >
              <option value="" disabled selected>Выберите материал</option>
              {cargoOptions.map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="comment" class="block text-sm font-medium text-gray-sub mb-2">Комментарий <span class="text-gray-sub/50">(необязательно)</span></label>
            <textarea
              id="comment"
              name="comment"
              rows="4"
              class="w-full bg-dark border border-white/10 rounded-xl px-4 py-3.5 text-white placeholder-gray-sub/50 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors resize-none"
              placeholder="Маршрут, объёмы, сроки..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-accent hover:bg-accent-hover text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all hover:translate-y-[-2px] hover:shadow-lg hover:shadow-accent/25 flex items-center justify-center gap-2"
          >
            <span>ОТПРАВИТЬ ЗАЯВКУ</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>

          <p class="text-gray-sub/50 text-xs text-center">
            Нажимая кнопку, вы соглашаетесь с&nbsp;обработкой персональных данных
          </p>
        </form>
      </div>

      <!-- Contact Info Sidebar -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Phone -->
        <a href={`tel:${contactInfo.phone.replace(/[\s()-]/g, '')}`} class="block bg-card border border-white/5 rounded-2xl p-8 hover:border-accent/30 transition-all group">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div class="text-gray-sub text-sm mb-1">Позвонить</div>
          <div class="text-white text-2xl font-bold group-hover:text-accent transition-colors">{contactInfo.phone}</div>
        </a>

        <!-- WhatsApp -->
        <a href={`https://wa.me/${contactInfo.whatsapp}`} target="_blank" rel="noopener noreferrer" class="block bg-card border border-white/5 rounded-2xl p-8 hover:border-green-500/30 transition-all group">
          <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-green-500/20 transition-colors">
            <svg class="w-6 h-6 text-green-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div class="text-gray-sub text-sm mb-1">Написать в WhatsApp</div>
          <div class="text-white text-2xl font-bold group-hover:text-green-400 transition-colors">{contactInfo.phone}</div>
        </a>

        <!-- Email -->
        <a href={`mailto:${contactInfo.email}`} class="block bg-card border border-white/5 rounded-2xl p-8 hover:border-accent/30 transition-all group">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="text-gray-sub text-sm mb-1">Написать на почту</div>
          <div class="text-white text-lg font-bold group-hover:text-accent transition-colors">{contactInfo.email}</div>
        </a>

        <!-- Schedule -->
        <div class="bg-accent/10 border border-accent/20 rounded-2xl p-6 text-center">
          <div class="text-accent font-bold text-lg">{contactInfo.schedule}</div>
        </div>
      </div>
    </div>
  </div>
</section>
