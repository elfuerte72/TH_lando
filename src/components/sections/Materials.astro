---
import { materials } from '@/data/materials';
---

<section id="materials" class="relative py-16 lg:py-20 bg-dark overflow-hidden">

  <!-- Subtle ambient glow -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[800px] blur-[120px]" style="background: radial-gradient(ellipse at 50% 50%, rgba(29,122,204,0.04) 0%, transparent 60%);"></div>
  </div>

  <!-- Decorative truck image — left side, desktop only -->
  <div class="hidden lg:block absolute left-0 -top-16 w-[340px] h-[420px] pointer-events-none z-0" style="-webkit-mask-image: radial-gradient(ellipse at 30% 50%, black 20%, transparent 70%); mask-image: radial-gradient(ellipse at 30% 50%, black 20%, transparent 70%);">
    <img
      src="/images/materials/truck-side.jpg"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="lazy"
    />
  </div>

  <div class="relative max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10 lg:mb-14 material-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center mx-auto">
        <span class="w-8 h-px bg-accent"></span>
        Услуги
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ЧТО <span class="text-accent">ПЕРЕВОЗИМ</span></span>
        </span>
      </h2>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed mt-4 max-w-2xl mx-auto">
        Любые сыпучие и&nbsp;инертные материалы. От&nbsp;карьера до&nbsp;объекта.
      </p>
    </div>

    <!-- Materials Grid -->
    <div id="materials-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-3">
      {materials.map((material) => (
        <article class="material-card group relative rounded-xl overflow-hidden border border-white/[0.06] hover:border-accent/30 transition-all duration-500 hover:translate-y-[-2px] h-[120px] lg:h-[140px]">
          <!-- Material photo background -->
          <div class="absolute inset-0">
            <img
              src={material.image}
              alt={material.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Minimal overlay only at bottom for text readability -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent"></div>
            <!-- Accent tint on hover -->
            <div class="absolute inset-0 bg-accent/0 group-hover:bg-accent/[0.06] transition-all duration-500"></div>
          </div>

          <!-- Content overlay -->
          <div class="relative h-full flex flex-col justify-end p-4 lg:p-5">
            <h3 class="text-base lg:text-lg font-bold text-white mb-0.5 " style="text-shadow: 0 1px 4px rgba(0,0,0,0.8);">{material.name}</h3>
            <p class="text-gray-200 text-sm leading-relaxed" style="text-shadow: 0 1px 4px rgba(0,0,0,0.9);">{material.description}</p>
          </div>

          <!-- Corner accent line -->
          <div class="absolute top-0 right-0 w-10 h-10 pointer-events-none">
            <div class="absolute top-0 right-0 w-full h-[1px] bg-gradient-to-l from-accent/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute top-0 right-0 h-full w-[1px] bg-gradient-to-b from-accent/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Header animation
  gsap.from('.material-header', {
    scrollTrigger: {
      trigger: '#materials',
      start: 'top 80%',
      toggleActions: 'play none none none',
    },
    y: 30,
    duration: 0.6,
    ease: 'power3.out',
  });

  // Cards staggered animation — no opacity to avoid flash-of-dark on load
  gsap.from('.material-card', {
    scrollTrigger: {
      trigger: '#materials-grid',
      start: 'top 90%',
      toggleActions: 'play none none none',
    },
    y: 30,
    duration: 0.5,
    stagger: 0.08,
    ease: 'power3.out',
  });
</script>
