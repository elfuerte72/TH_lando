---
import { materials } from '@/data/materials';
---

<section id="materials" class="relative py-16 lg:py-20 bg-dark overflow-hidden">

  <!-- Subtle ambient glow -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[800px] blur-[120px]" style="background: radial-gradient(ellipse at 50% 50%, rgba(29,122,204,0.04) 0%, transparent 60%);"></div>
  </div>

  <!-- Decorative truck image — right side, desktop only -->
  <div id="materials-truck" class="hidden lg:block absolute right-[-120px] xl:right-[-60px] top-2 w-[520px] xl:w-[580px] h-[360px] pointer-events-none overflow-hidden" style="z-index: 1; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 30%, black 100%); mask-image: linear-gradient(to right, transparent 0%, black 30%, black 100%);">
    <img
      src="/images/materials/truck-side.webp"
      alt=""
      class="w-full h-full object-contain object-center opacity-70"
      loading="lazy"
    />
  </div>

  <div class="relative z-20 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10 lg:mb-14 material-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center mx-auto">
        <span class="w-8 h-px bg-accent"></span>
        Услуги
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ЧТО <span class="text-accent">ПЕРЕВОЗИМ</span></span>
        </span>
      </h2>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed mt-4 max-w-2xl mx-auto">
        Материалы, транспортировка которых осуществляется самосвалами или шламовозами.
      </p>
    </div>

    <!-- Materials Grid -->
    <div id="materials-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-3">
      {materials.map((material) => (
        <article class="material-card group relative rounded-xl overflow-hidden border border-white/[0.06] hover:border-accent/30 active:border-accent/40 transition-all duration-500 hover:translate-y-[-2px] active:scale-[0.98] h-[160px] sm:h-[140px] lg:h-[140px]">
          <!-- Material photo background -->
          <div class="absolute inset-0">
            <img
              src={material.image}
              alt={material.name}
              class="w-full h-full object-cover sm:transition-transform sm:duration-700 sm:group-hover:scale-110"
              loading="lazy"
              decoding="async"
            />
            <!-- Minimal overlay only at bottom for text readability -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/20"></div>
            <!-- Accent tint on hover -->
            <div class="absolute inset-0 bg-accent/0 group-hover:bg-accent/[0.06] transition-all duration-500"></div>
          </div>

          <!-- Content overlay -->
          <div class="relative h-full flex flex-col justify-end p-4 lg:p-5">
            <h3 class="text-base lg:text-lg font-bold text-white mb-0.5 " style="text-shadow: 0 1px 4px rgba(0,0,0,0.8);">{material.name}</h3>
            <p class="text-gray-200 text-sm leading-relaxed" style="text-shadow: 0 1px 4px rgba(0,0,0,0.9);">{material.description}</p>
          </div>

          <!-- Corner accent line -->
          <div class="absolute top-0 right-0 w-10 h-10 pointer-events-none">
            <div class="absolute top-0 right-0 w-full h-[1px] bg-gradient-to-l from-accent/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute top-0 right-0 h-full w-[1px] bg-gradient-to-b from-accent/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
        </article>
      ))}
    </div>

    <!-- License -->
    <div class="license-badge mt-8 lg:mt-12 rounded-xl bg-card border border-white/[0.06] border-l-2 border-l-accent p-5 lg:p-6 flex flex-col sm:flex-row items-start gap-4 sm:gap-5">

      <!-- Shield icon -->
      <div class="shrink-0 w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center">
        <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Content -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2">
          <h3 class="text-white font-heading font-bold text-sm lg:text-base uppercase tracking-wider">Лицензия на транспортирование отходов</h3>
          <div class="flex items-center gap-1.5">
            {['III', 'IV'].map((cls) => (
              <span class="w-6 h-6 rounded bg-white/[0.06] flex items-center justify-center text-accent font-heading font-bold text-[11px]">
                {cls}
              </span>
            ))}
            <span class="text-gray-dim text-xs ml-1">класс опасности</span>
          </div>
        </div>
        <p class="text-gray-sub text-sm leading-relaxed">
          Одна из&nbsp;немногих компаний в&nbsp;регионе.
        </p>
        <a href="/docs/license.pdf" download="Лицензия_ТракХолдинг.pdf" class="inline-flex items-center gap-2 mt-3 px-4 py-2.5 min-h-[44px] rounded-lg bg-accent/10 hover:bg-accent/20 active:bg-accent/30 border border-accent/20 text-accent text-sm font-semibold transition-all duration-200">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="7 10 12 15 17 10" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="12" y1="15" x2="12" y2="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Скачать лицензию
        </a>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;

  // Truck drive-in animation — desktop only (element is hidden on mobile)
  if (isDesktop) gsap.from('#materials-truck', {
    scrollTrigger: {
      trigger: '#materials',
      start: 'top 85%',
      toggleActions: 'play none none reverse',
    },
    x: 400,
    opacity: 0,
    duration: 1.2,
    ease: 'power2.out',
  });

  // Header animation
  gsap.from('.material-header', {
    scrollTrigger: {
      trigger: '#materials',
      start: 'top 80%',
      toggleActions: 'play none none none',
    },
    y: 30,
    duration: 0.6,
    ease: 'power3.out',
  });

  // Cards staggered animation — no opacity to avoid flash-of-dark on load
  gsap.from('.material-card', {
    scrollTrigger: {
      trigger: '#materials-grid',
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    y: 30,
    duration: 0.5,
    stagger: 0.08,
    ease: 'power3.out',
  });

  // License badge animation
  gsap.from('.license-badge', {
    scrollTrigger: {
      trigger: '.license-badge',
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    y: 20,
    opacity: 0,
    duration: 0.7,
    ease: 'power3.out',
  });
</script>
