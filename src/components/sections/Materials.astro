---
import { materials } from '@/data/materials';

const materialIcons: Record<string, string> = {
  'Буровой шлам': 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  'Щебень': 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  'Песок': 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  'Грунт': 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  'Уголь и руда': 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z',
  'Асфальт': 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
};
---

<section id="materials" class="py-20 lg:py-30 bg-dark">
  <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-2xl mb-16">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest">Услуги</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mt-3 mb-6">ЧТО ПЕРЕВОЗИМ</h2>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Любые сыпучие и&nbsp;инертные материалы. От&nbsp;карьера до&nbsp;объекта.
      </p>
    </div>

    <!-- Materials Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {materials.map((material) => (
        <article class="group relative bg-card rounded-2xl p-8 border border-white/5 hover:border-accent/30 transition-all duration-300 hover:translate-y-[-4px]">
          <!-- Icon -->
          <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={materialIcons[material.name] || 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'} />
            </svg>
          </div>

          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-accent transition-colors">{material.name}</h3>
          <p class="text-gray-sub leading-relaxed">{material.description}</p>

          <!-- Hover arrow -->
          <div class="absolute top-8 right-8 opacity-0 group-hover:opacity-100 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
        </article>
      ))}
    </div>

    <!-- License Badge -->
    <div class="bg-accent/10 border border-accent/30 rounded-2xl p-8 lg:p-10 flex flex-col lg:flex-row items-start lg:items-center gap-6">
      <div class="flex-shrink-0 w-16 h-16 bg-accent rounded-xl flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <div>
        <h3 class="text-xl lg:text-2xl font-bold text-white mb-2">Лицензия на обращение с отходами I–IV класса опасности</h3>
        <p class="text-gray-sub leading-relaxed">
          Одна из немногих компаний в&nbsp;регионе с&nbsp;данной лицензией. Сбор, транспортирование, обработка, утилизация, обезвреживание, размещение отходов.
        </p>
      </div>
    </div>
  </div>
</section>
