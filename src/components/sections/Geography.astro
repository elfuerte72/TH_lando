---
import { locations, sectors } from '@/data/locations';

const sectorIcons: Record<string, string> = {
  oil: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  road: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  factory: 'M3 21h18M3 10h18M3 7l6-4v4M9 21V10m0 0l6-4v4m0 7v4m0-4l6-4v4m0 0v4',
};
---

<section id="geography" class="py-20 lg:py-30 bg-dark-lighter">
  <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-2xl mb-16">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest">Покрытие</span>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold mt-3 mb-6">ГЕОГРАФИЯ РАБОТ</h2>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        От Тюмени до Крайнего Севера. ХМАО. ЯНАО. Иркутская область.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Map placeholder / Location grid -->
      <div class="lg:col-span-3 bg-card border border-white/5 rounded-2xl p-8 lg:p-10">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {locations.map((location) => (
            <div class={`flex items-center gap-2 p-3 rounded-xl transition-colors ${location.highlight ? 'bg-accent/10 border border-accent/30' : 'hover:bg-dark/50'}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 flex-shrink-0 ${location.highlight ? 'text-accent' : 'text-gray-sub'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class={`text-sm ${location.highlight ? 'text-accent font-semibold' : 'text-white/80'}`}>{location.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-2 space-y-6">
        <!-- New Direction Banner -->
        <div class="bg-accent rounded-2xl p-8 text-white">
          <div class="flex items-center gap-2 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <span class="font-semibold uppercase text-sm tracking-wider">Новое направление</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Ковыктинское месторождение</h3>
          <p class="text-white/80 text-sm leading-relaxed">
            Газопровод «Сила Сибири». Поставка газа в&nbsp;Китай.
          </p>
        </div>

        <!-- Sectors -->
        <div class="bg-card border border-white/5 rounded-2xl p-8">
          <h3 class="text-lg font-bold mb-6">Секторы работы</h3>
          <div class="grid grid-cols-2 gap-4">
            {sectors.map((sector) => (
              <div class="flex items-center gap-3 p-3 rounded-xl bg-dark/50">
                <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={sectorIcons[sector.icon] || sectorIcons.building} />
                  </svg>
                </div>
                <span class="text-white/90 text-sm font-medium">{sector.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
