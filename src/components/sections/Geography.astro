---
import { locations, sectors } from '@/data/locations';

const yandexMapsKey = import.meta.env.PUBLIC_YANDEX_MAPS_KEY;

const sectorIcons: Record<string, string> = {
  oil: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  road: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  factory: 'M3 21h18M3 10h18M3 7l6-4v4M9 21V10m0 0l6-4v4m0 7v4m0-4l6-4v4m0 0v4',
  people: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm14 10v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
};
---

<section id="geography" class="py-20 lg:py-30 bg-dark">
  <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 lg:mb-16 geo-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        Портфолио
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ГЕОГРАФИЯ <span class="text-accent">РАБОТ</span></span>
        </span>
      </h2>
      <p class="text-gray-sub text-base lg:text-lg leading-relaxed mt-5 max-w-xl mx-auto">
        От Кургана до Крайнего севера (ХМАО, ЯНАО). От Урала до Иркутской области.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Map -->
      <div class="lg:col-span-3 relative">
        <div id="yandex-map" class="w-full h-[350px] sm:h-[420px] lg:h-[500px] rounded-2xl overflow-hidden" data-api-key={yandexMapsKey}></div>
        <!-- Vignette overlay -->
        <div class="absolute inset-0 pointer-events-none rounded-2xl"
          style="box-shadow: inset 0 0 60px 30px #0a0a0d;"
        ></div>
      </div>

      <!-- Sidebar — stretch to match map height -->
      <div class="lg:col-span-2 flex flex-col gap-4 lg:h-[500px]">
        <!-- New Direction Banner -->
        <div class="relative bg-gradient-to-br from-accent to-accent/80 rounded-2xl p-5 sm:p-6 text-white overflow-hidden group">
          <div class="relative">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-yellow-400/90 text-black rounded-full mb-4 shadow-[0_0_14px_rgba(250,204,21,0.5),0_0_28px_rgba(250,204,21,0.25)]">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-600 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-yellow-600"></span>
              </span>
              <span class="font-bold uppercase text-xs tracking-wider">Новое направление</span>
            </div>
            <h3 class="text-xl lg:text-2xl font-black mb-3 leading-tight">Ковыктинское<br/>месторождение</h3>
            <div class="w-10 h-px bg-white/30 mb-3"></div>
            <p class="text-white/85 text-sm leading-relaxed">
              Газопровод «Сила Сибири».<br/>Поставка газа в&nbsp;Китай.
            </p>
          </div>
        </div>

        <!-- Sectors -->
        <div class="bg-card border border-white/5 rounded-2xl p-5 sm:p-6 flex-1 flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-1 h-6 bg-accent rounded-full"></div>
            <h3 class="text-lg font-bold uppercase tracking-wide">Наши Партнеры</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 flex-1 content-center">
            {sectors.map((sector) => (
              <div class="geo-sector-card flex items-center gap-3 p-3 rounded-xl border border-white/5 bg-dark/40 hover:border-accent/30 hover:bg-accent/5 transition-all duration-300 min-w-0">
                <div class="w-9 h-9 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={sectorIcons[sector.icon] || sectorIcons.building} />
                  </svg>
                </div>
                <span class="text-white/90 text-xs font-semibold tracking-wide leading-tight min-w-0">{sector.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Location data for client-side script -->
<script type="application/json" id="geo-locations-data" set:html={JSON.stringify(locations)} />

<script is:inline>
  (function() {
    // Load Yandex Maps API 2.1
    function loadYandexMaps() {
      return new Promise(function(resolve, reject) {
        if (typeof ymaps !== 'undefined') { resolve(); return; }
        var s = document.createElement('script');
        var apiKey = document.getElementById('yandex-map').getAttribute('data-api-key');
        s.src = 'https://api-maps.yandex.ru/2.1/?apikey=' + apiKey + '&lang=ru_RU';
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    // Dark theme customization for Yandex Maps 2.1
    var darkCustomization = [
      // Water — deep dark blue
      { tags: 'water', elements: 'geometry', stylers: { hue: '#0a1628', saturation: -0.8, lightness: -0.7 } },
      // Land — very dark
      { tags: 'land', elements: 'geometry', stylers: { hue: '#0a0a0d', saturation: -1, lightness: -0.85 } },
      // Roads — subtle dark gray
      { tags: 'road', elements: 'geometry.fill', stylers: { hue: '#1a1a2e', saturation: -1, lightness: -0.6 } },
      { tags: 'road', elements: 'geometry.outline', stylers: { hue: '#111118', saturation: -1, lightness: -0.8 } },
      // Road labels
      { tags: 'road', elements: 'label.text.fill', stylers: { hue: '#8888aa', saturation: -0.5, lightness: -0.2 } },
      { tags: 'road', elements: 'label.text.outline', stylers: { hue: '#0a0a0d', saturation: -1, lightness: -0.9 } },
      // Buildings — slightly lighter than land
      { tags: 'building', elements: 'geometry', stylers: { hue: '#12121a', saturation: -1, lightness: -0.75 } },
      // Vegetation — dark muted green
      { tags: 'vegetation', elements: 'geometry', stylers: { hue: '#0d1a0d', saturation: -0.8, lightness: -0.8 } },
      // Landscape
      { tags: 'landscape', elements: 'geometry', stylers: { hue: '#0e0e14', saturation: -1, lightness: -0.8 } },
      // Admin boundaries — very subtle
      { tags: 'admin', elements: 'geometry', stylers: { hue: '#1D7ACC', saturation: -0.5, lightness: -0.6, opacity: 0.3 } },
      // All labels — muted
      { tags: 'country', elements: 'label.text.fill', stylers: { hue: '#6a6a8a', saturation: -0.5, lightness: -0.2 } },
      { tags: 'country', elements: 'label.text.outline', stylers: { hue: '#0a0a0d', saturation: -1, lightness: -0.9 } },
      { tags: 'region', elements: 'label.text.fill', stylers: { hue: '#555570', saturation: -0.5, lightness: -0.3 } },
      { tags: 'region', elements: 'label.text.outline', stylers: { hue: '#0a0a0d', saturation: -1, lightness: -0.9 } },
      { tags: 'locality', elements: 'label.text.fill', stylers: { hue: '#7a7a9a', saturation: -0.5, lightness: -0.15 } },
      { tags: 'locality', elements: 'label.text.outline', stylers: { hue: '#0a0a0d', saturation: -1, lightness: -0.9 } },
    ];

    function initGeographyMap() {
      ymaps.ready(function() {
        var mapContainer = document.getElementById('yandex-map');
        if (!mapContainer) return;

        var locationsData = JSON.parse(document.getElementById('geo-locations-data').textContent);

        // Create map
        var map = new ymaps.Map(mapContainer, {
          center: [63, 72],
          zoom: 4,
          controls: ['zoomControl'],
          type: 'yandex#map'
        }, {
          suppressMapOpenBlock: true,
          yandexMapDisablePoiInteractivity: true
        });

        // Apply dark customization via CSS filter on ground pane
        // API 2.1 customization API is limited; CSS filter is most reliable for dark theme
        var groundPane = map.panes.get('ground').getElement();
        groundPane.style.filter = 'invert(0.92) hue-rotate(180deg) saturate(0.3) brightness(0.6)';
        groundPane.style.webkitFilter = 'invert(0.92) hue-rotate(180deg) saturate(0.3) brightness(0.6)';

        // Custom balloon content layout
        var BalloonContentLayout = ymaps.templateLayoutFactory.createClass(
          '<div class="geo-balloon">' +
            '<div class="geo-balloon-header">' +
              '<span class="geo-balloon-title">{{ properties.name }}</span>' +
            '</div>' +
            '<div class="geo-balloon-body">{{ properties.description }}</div>' +
          '</div>'
        );

        // Custom icon layout
        var MarkerLayout = ymaps.templateLayoutFactory.createClass(
          '<div class="geo-marker-wrapper" style="position:relative;width:0;height:0;">' +
            '<div class="$[properties.markerClass]"></div>' +
            '<div class="$[properties.pulseClass]"></div>' +
            '<div class="$[properties.labelClass]">$[properties.name]</div>' +
          '</div>'
        );

        // Add placemarks
        locationsData.forEach(function(loc) {
          var isHighlight = !!loc.highlight;

          var placemark = new ymaps.Placemark(
            [loc.lat, loc.lng],
            {
              name: loc.name,
              description: loc.description || '',
              hintContent: loc.name,
              markerClass: isHighlight ? 'geo-marker geo-marker--highlight' : 'geo-marker',
              pulseClass: isHighlight ? 'geo-pulse geo-pulse--highlight' : 'geo-pulse',
              labelClass: isHighlight ? 'geo-label geo-label--highlight' : 'geo-label'
            },
            {
              iconLayout: MarkerLayout,
              iconShape: {
                type: 'Circle',
                coordinates: [0, 0],
                radius: 20
              },
              balloonContentLayout: BalloonContentLayout,
              balloonPanelMaxMapArea: 0,
              hideIconOnBalloonOpen: false,
              balloonOffset: [0, -15]
            }
          );

          map.geoObjects.add(placemark);
        });

        // Fit bounds to show all markers with padding
        if (map.geoObjects.getLength() > 0) {
          var bounds = map.geoObjects.getBounds();
          if (bounds) {
            map.setBounds(bounds, {
              checkZoomRange: true,
              zoomMargin: 40
            });
          }
        }
      });
    }

    // Load and init
    loadYandexMaps().then(function() {
      initGeographyMap();
    }).catch(function(err) {
      console.error('Failed to load Yandex Maps API:', err);
    });
  })();
</script>

<style is:global>
  /* ── Custom marker styles ── */
  .geo-marker-wrapper {
    position: relative;
    cursor: pointer;
    z-index: 1;
    width: 0;
    height: 0;
  }

  .geo-marker-wrapper:hover {
    z-index: 10;
  }

  .geo-marker {
    width: 12px;
    height: 12px;
    background: #1D7ACC;
    border-radius: 50%;
    border: 2px solid rgba(29, 122, 204, 0.3);
    box-shadow: 0 0 8px rgba(29, 122, 204, 0.5);
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .geo-marker-wrapper:hover .geo-marker {
    transform: translate(-50%, -50%) scale(1.4);
    box-shadow: 0 0 16px rgba(29, 122, 204, 0.8);
  }

  .geo-marker--highlight {
    width: 16px;
    height: 16px;
    background: #f59e0b;
    border-color: rgba(245, 158, 11, 0.3);
    box-shadow: 0 0 12px rgba(245, 158, 11, 0.6);
    transform: translate(-50%, -50%);
  }

  .geo-marker-wrapper:hover .geo-marker--highlight {
    transform: translate(-50%, -50%) scale(1.4);
    box-shadow: 0 0 20px rgba(245, 158, 11, 0.9);
  }

  /* ── Pulse animation ── */
  .geo-pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid rgba(29, 122, 204, 0.4);
    transform: translate(-50%, -50%);
    animation: geo-pulse-ring 2.5s ease-out infinite;
    pointer-events: none;
  }

  .geo-pulse--highlight {
    position: absolute;
    top: 0;
    left: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid rgba(245, 158, 11, 0.5);
    transform: translate(-50%, -50%);
    animation: geo-pulse-ring-highlight 2.5s ease-out infinite;
    pointer-events: none;
  }

  @keyframes geo-pulse-ring {
    0% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(0.3);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(1.2);
    }
  }

  @keyframes geo-pulse-ring-highlight {
    0% {
      opacity: 0.9;
      transform: translate(-50%, -50%) scale(0.3);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(1.4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .geo-pulse,
    .geo-pulse--highlight {
      animation: none;
    }
  }

  /* ── Label ── */
  .geo-label {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.02em;
    pointer-events: none;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.9);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .geo-marker-wrapper:hover .geo-label {
    opacity: 1;
  }

  .geo-label--highlight {
    color: #f59e0b;
    font-weight: 600;
    font-size: 12px;
    opacity: 1;
  }

  .geo-marker-wrapper:hover .geo-label--highlight {
    opacity: 1;
  }

  /* ── Balloon (popup) styles ── */
  /* Override default Yandex balloon styles (version-agnostic selectors) */
  [class*="balloon"]:not([class*="balloon__"]):not(.geo-balloon) {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6) !important;
    border-radius: 12px !important;
  }

  [class*="balloon__layout"] {
    background: transparent !important;
    border: none !important;
    border-radius: 12px !important;
    overflow: hidden !important;
  }

  [class*="balloon__content"] {
    padding: 0 !important;
    margin: 0 !important;
    background: transparent !important;
  }

  [class*="balloon__close-button"] {
    display: none !important;
  }

  [class*="balloon__tail"],
  [class*="balloon__tail"]::after {
    background: #1a1a2e !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
  }

  .geo-balloon {
    width: 260px;
    background: #1a1a2e;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .geo-balloon-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(29, 122, 204, 0.1);
    border-top: 2px solid #1D7ACC;
  }

  .geo-balloon-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .geo-balloon-close {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 18px;
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }

  .geo-balloon-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .geo-balloon-body {
    padding: 10px 14px 12px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Hide Yandex copyright area background for dark theme */
  [class*="copyrights"] {
    opacity: 0.4;
  }

  /* Zoom control dark styling (version-agnostic) */
  [class*="-zoom"] {
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  [class*="-zoom"]:hover {
    opacity: 1;
  }
</style>
