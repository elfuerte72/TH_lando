---
import { locations, sectors } from '@/data/locations';
import fs from 'node:fs';
import path from 'node:path';

const sectorIcons: Record<string, string> = {
  oil: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  road: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  factory: 'M3 21h18M3 10h18M3 7l6-4v4M9 21V10m0 0l6-4v4m0 7v4m0-4l6-4v4m0 0v4',
};

// Read the Russia SVG at build time (ArmGono/ru-svg-map, viewBox 0 0 1002 568)
const svgPath = path.resolve('russia-new.svg');
let svgContent = fs.readFileSync(svgPath, 'utf-8');

// Extract path elements from single-line <path> tags
const regions: { d: string; id: string; cls: string }[] = [];
const pathRegex = /<path\s+class="([^"]*)"\s+id="(RU-[^"]*)"\s+d="([^"]*)"/g;
let regMatch;
while ((regMatch = pathRegex.exec(svgContent)) !== null) {
  regions.push({ cls: regMatch[1], id: regMatch[2], d: regMatch[3] });
}

// Highlighted regions (HMAO, YANAO, Tyumen Oblast)
// Irkutsk excluded — only Ковыктинское there, already has its own highlight marker
const highlightedRegions = new Set(['RU-KHM', 'RU-YAN', 'RU-TYU']);

// Convert geo coordinates to SVG coordinates using affine projection
// Calibrated from known region centroids: Moscow, St.Petersburg, Ekaterinburg
function geoToSvg(lat: number, lng: number): { x: number; y: number } {
  return {
    x: 6.0872 * lng + 12.4909 * lat - 800.8702,
    y: 3.5620 * lng - 11.8848 * lat + 777.6780,
  };
}

// Small cities too close together — exclude entirely to avoid clutter
const excludedCities = new Set(['Ялуторовск', 'Заводоуковск', 'Ярково', 'Демьянское', 'Горноправдинск']);

// Compute city positions
const cityMarkers = locations
  .filter((loc) => !excludedCities.has(loc.name))
  .map((loc, i) => {
    const pos = geoToSvg(loc.lat, loc.lng);
    return { ...loc, svgX: pos.x, svgY: pos.y, index: i };
  });

// Label placement offsets
const labelLeft: string[] = ['Надым', 'Сабетта', 'Нижневартовск', 'Лабытнанги'];
const labelBelow: string[] = ['Коротчаево', 'Бованенково'];
const labelAbove: string[] = ['Муравленко', 'Салехард'];

function getLabelAnchor(name: string): { dx: number; dy: number; anchor: string } {
  if (labelLeft.includes(name)) return { dx: -8, dy: 4, anchor: 'end' };
  if (labelBelow.includes(name)) return { dx: 0, dy: 14, anchor: 'middle' };
  if (labelAbove.includes(name)) return { dx: 0, dy: -10, anchor: 'middle' };
  return { dx: 8, dy: 4, anchor: 'start' };
}
---

<section id="geography" class="py-20 lg:py-30 bg-dark">
  <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 lg:mb-16 geo-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        Регионы
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block">ГЕОГРАФИЯ <span class="text-accent">РАБОТ</span></span>
        </span>
      </h2>
      <p class="text-gray-sub text-base lg:text-lg leading-relaxed mt-5 max-w-xl mx-auto">
        От Тюмени до Крайнего Севера. ХМАО. ЯНАО. Иркутская область.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- Map -->
      <div class="lg:col-span-3 relative">
        <div class="w-full h-[350px] sm:h-[420px] lg:h-[500px] rounded-2xl overflow-hidden geo-map-wrap">
          <svg
            id="geography-map-svg"
            viewBox="210 110 440 460"
            preserveAspectRatio="xMidYMid meet"
            class="w-full h-full"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <!-- Glow filter for markers -->
              <filter id="glow-accent" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
              <filter id="glow-highlight" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="4" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
              <!-- Radial gradient for highlighted regions -->
              <radialGradient id="region-glow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="rgba(29, 122, 204, 0.15)" />
                <stop offset="100%" stop-color="rgba(29, 122, 204, 0.03)" />
              </radialGradient>
            </defs>

            <!-- Russia regions -->
            <g class="geo-regions">
              {regions.map((region) => (
                <path
                  d={region.d}
                  class={highlightedRegions.has(region.id) ? 'geo-region geo-region--active' : 'geo-region'}
                  data-id={region.id}
                />
              ))}
            </g>

            <!-- Subtle connection lines from Тюмень hub -->
            <g class="geo-connections" opacity="0.08">
              {(() => {
                const tyumen = cityMarkers.find(c => c.name === 'Тюмень');
                if (!tyumen) return null;
                return cityMarkers
                  .filter(c => c.name !== 'Тюмень' && !c.highlight)
                  .map(c => (
                    <line
                      x1={tyumen.svgX} y1={tyumen.svgY}
                      x2={c.svgX} y2={c.svgY}
                      stroke="var(--color-accent)"
                      stroke-width="0.5"
                      stroke-dasharray="3 4"
                    />
                  ));
              })()}
            </g>

            <!-- City markers -->
            {cityMarkers.map((city) => {
              const isHighlight = !!city.highlight;
              const r = isHighlight ? 5 : 3;
              const label = getLabelAnchor(city.name);
              return (
                <g class={`geo-city ${isHighlight ? 'geo-city--highlight' : ''}`}>
                  {/* Pulse ring */}
                  <circle
                    cx={city.svgX}
                    cy={city.svgY}
                    r={r * 2.5}
                    fill="none"
                    stroke={isHighlight ? '#f59e0b' : 'var(--color-accent)'}
                    stroke-width="0.5"
                    class="geo-pulse-ring"
                    style={`animation-delay: ${city.index * 0.15}s`}
                  />
                  {/* Outer glow */}
                  <circle
                    cx={city.svgX}
                    cy={city.svgY}
                    r={r * 1.5}
                    fill={isHighlight ? 'rgba(245, 158, 11, 0.2)' : 'rgba(29, 122, 204, 0.2)'}
                  />
                  {/* Core dot */}
                  <circle
                    cx={city.svgX}
                    cy={city.svgY}
                    r={r}
                    fill={isHighlight ? '#f59e0b' : 'var(--color-accent)'}
                    filter={isHighlight ? 'url(#glow-highlight)' : 'url(#glow-accent)'}
                  />
                  {/* Label */}
                  <text
                    x={city.svgX + label.dx}
                    y={city.svgY + label.dy}
                    text-anchor={label.anchor}
                    class={`geo-svg-label ${isHighlight ? 'geo-svg-label--highlight' : ''}`}
                  >
                    {city.name}
                  </text>
                </g>
              );
            })}
          </svg>
        </div>
        <!-- Vignette overlay -->
        <div class="absolute inset-0 pointer-events-none rounded-2xl"
          style="box-shadow: inset 0 0 80px 40px #0a0a0d;"
        ></div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-2 space-y-6">
        <!-- New Direction Banner -->
        <div class="relative bg-gradient-to-br from-accent to-accent/80 rounded-2xl p-8 text-white overflow-hidden group">
          <!-- Decorative background pattern -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="absolute bottom-0 left-0 w-20 h-20 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
          <div class="relative">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/15 backdrop-blur-sm rounded-full mb-5">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
              </span>
              <span class="font-semibold uppercase text-xs tracking-wider">Новое направление</span>
            </div>
            <h3 class="text-xl lg:text-2xl font-black mb-3 leading-tight">Ковыктинское<br/>месторождение</h3>
            <div class="w-10 h-px bg-white/30 mb-3"></div>
            <p class="text-white/85 text-sm leading-relaxed">
              Газопровод «Сила Сибири».<br/>Поставка газа в&nbsp;Китай.
            </p>
          </div>
        </div>

        <!-- Sectors -->
        <div class="bg-card border border-white/5 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-accent rounded-full"></div>
            <h3 class="text-lg font-bold uppercase tracking-wide">Секторы работы</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {sectors.map((sector) => (
              <div class="geo-sector-card flex items-center gap-4 p-4 rounded-xl border border-white/5 bg-dark/40 hover:border-accent/30 hover:bg-accent/5 transition-all duration-300">
                <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={sectorIcons[sector.icon] || sectorIcons.building} />
                  </svg>
                </div>
                <span class="text-white/90 text-sm font-semibold tracking-wide">{sector.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Region base styling */
  .geo-region {
    fill: #151520;
    stroke: #2a2a3a;
    stroke-width: 0.5;
    transition: fill 0.3s ease;
  }

  .geo-region--active {
    fill: #1a2535;
    stroke: rgba(29, 122, 204, 0.4);
    stroke-width: 0.8;
  }

  /* SVG labels */
  .geo-svg-label {
    fill: rgba(255, 255, 255, 0.8);
    font-family: 'Inter', sans-serif;
    font-size: 6px;
    letter-spacing: 0.03em;
  }

  .geo-svg-label--highlight {
    fill: #f59e0b;
    font-size: 7px;
    font-weight: 600;
  }

  /* Pulse animation for marker rings */
  .geo-pulse-ring {
    animation: svg-pulse 2.5s ease-in-out infinite;
    transform-origin: center;
  }

  @keyframes svg-pulse {
    0%, 100% {
      opacity: 0;
      r: 3;
    }
    50% {
      opacity: 0.6;
      r: 8;
    }
  }

  .geo-city--highlight .geo-pulse-ring {
    animation: svg-pulse-highlight 2.5s ease-in-out infinite;
  }

  @keyframes svg-pulse-highlight {
    0%, 100% {
      opacity: 0;
      r: 4;
    }
    50% {
      opacity: 0.7;
      r: 12;
    }
  }
</style>
