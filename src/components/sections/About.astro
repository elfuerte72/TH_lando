---
---

<section id="about" class="relative py-16 lg:py-28 overflow-hidden">

  <!-- LAYER 1: Background photo with vignette -->
  <div class="absolute inset-0">
    <img
      src="/images/about/team.png"
      alt=""
      loading="lazy"
      class="about-bg w-full h-full object-cover"
      style="object-position: 50% 45%;"
    />
    <div class="absolute inset-0 bg-dark/80"></div>
    <div class="absolute inset-x-0 top-0 h-24 lg:h-48 bg-gradient-to-b from-dark to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-24 lg:h-48 bg-gradient-to-t from-dark to-transparent"></div>
    <div class="absolute inset-y-0 left-0 w-16 lg:w-40 bg-gradient-to-r from-dark to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-16 lg:w-40 bg-gradient-to-l from-dark to-transparent"></div>
  </div>

  <!-- LAYER 2: Content -->
  <div class="relative z-10 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 lg:mb-16 about-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        О нас
        <span class="w-8 h-px bg-accent"></span>
      </span>
      <h2 class="text-3xl sm:text-5xl lg:text-7xl font-black mt-4 leading-[0.9]">
        <span class="block overflow-hidden">
          <span class="inline-block"><span class="text-accent">О</span> <span class="text-accent">КОМПАНИИ</span></span>
        </span>
      </h2>
    </div>

    <!-- Text content -->
    <div class="max-w-3xl mx-auto space-y-6 about-text">
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        ООО <span class="text-accent font-semibold">«Трак Холдинг»</span> — транспортная компания, специализирующаяся на&nbsp;перевозке сыпучих и&nbsp;инертных материалов в&nbsp;сложных условиях Западной Сибири и&nbsp;Крайнего Севера.
      </p>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Компания основана людьми, которые начинали за&nbsp;рулём самосвала. Мы&nbsp;знаем эту работу изнутри — от&nbsp;первого рейса до&nbsp;управления автопарком из&nbsp;десятков машин.
      </p>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Мы&nbsp;работали там, где другие отказываются: <span class="text-white font-medium">Сабетта, Бованенково, Ковыктинское месторождение</span>. Наши машины выдерживают экстремальные температуры и&nbsp;бездорожье, потому что каждая единица техники — <span class="text-accent font-semibold">полный привод 6×6</span>.
      </p>
    </div>

  </div>
</section>

<style>
  .about-bg {
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    will-change: transform;
    filter: brightness(0.85);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Background parallax
  const bgEl = document.querySelector('.about-bg');
  if (bgEl) {
    gsap.to(bgEl, {
      scrollTrigger: {
        trigger: '#about',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 0.8,
      },
      y: -60,
      ease: 'none',
    });
  }

  // Header reveal
  const header = document.querySelector('.about-header');
  if (header) {
    gsap.from(header, {
      scrollTrigger: {
        trigger: '#about',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
    });
  }

  // Text paragraphs staggered reveal
  const paragraphs = document.querySelectorAll('.about-text p');
  paragraphs.forEach((p, i) => {
    gsap.from(p, {
      scrollTrigger: {
        trigger: p,
        start: 'top 90%',
        toggleActions: 'play none none none',
      },
      y: 25,
      opacity: 0,
      duration: 0.6,
      delay: i * 0.15,
      ease: 'power3.out',
    });
  });
</script>
