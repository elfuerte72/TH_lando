---
---

<section id="about" class="relative py-16 lg:py-28 overflow-hidden">

  <!-- LAYER 1: Background photo with vignette -->
  <div class="absolute inset-0">
    <img
      src="/images/about/team.webp"
      alt=""
      loading="lazy"
      class="about-bg w-full h-full object-cover"
      style="object-position: 50% 45%;"
    />
    <div class="absolute inset-0 bg-dark/80"></div>
    <div class="absolute inset-x-0 top-0 h-24 lg:h-48 bg-gradient-to-b from-dark to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-24 lg:h-48 bg-gradient-to-t from-dark to-transparent"></div>
    <div class="absolute inset-y-0 left-0 w-16 lg:w-40 bg-gradient-to-r from-dark to-transparent"></div>
    <div class="absolute inset-y-0 right-0 w-16 lg:w-40 bg-gradient-to-l from-dark to-transparent"></div>
  </div>

  <!-- LAYER 2: Content -->
  <div class="relative z-10 max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-10 lg:mb-16 about-header">
      <span class="text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3 justify-center">
        <span class="w-8 h-px bg-accent"></span>
        Наша команда
        <span class="w-8 h-px bg-accent"></span>
      </span>
    </div>

    <!-- Text content -->
    <div class="max-w-3xl mx-auto space-y-6 about-text">
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Основатели компании глубоко знают отрасль изнутри — от&nbsp;первых рейсов за&nbsp;рулём самосвала до&nbsp;управления крупным автопарком. Этот практический опыт позволяет нам выстраивать процессы так, чтобы обеспечивать высокий уровень надёжности и&nbsp;эффективности.
      </p>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Мы&nbsp;уделяем особое внимание персоналу и&nbsp;техническому состоянию транспорта, что гарантирует стабильную работу даже в&nbsp;условиях экстремальных температур, бездорожья и&nbsp;сложного горного рельефа. Мы&nbsp;работаем круглосуточно и&nbsp;берёмся за&nbsp;задачи там, где другие участники рынка отказываются.
      </p>
      <p class="text-gray-sub text-lg lg:text-xl leading-relaxed">
        Для нас принципиально важно соблюдать договорённости и&nbsp;выполнять взятые на&nbsp;себя обязательства перед заказчиком — даже если это связано с&nbsp;дополнительными затратами.
      </p>
    </div>

  </div>
</section>

<style>
  .about-bg {
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 35%, transparent 100%);
    will-change: transform;
    filter: brightness(0.85);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const isDesktop = window.matchMedia('(min-width: 768px)').matches;

  // Background parallax (desktop only — causes jank on mobile)
  const bgEl = document.querySelector('.about-bg');
  if (bgEl && isDesktop) {
    gsap.to(bgEl, {
      scrollTrigger: {
        trigger: '#about',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 0.8,
      },
      y: -60,
      ease: 'none',
    });
  }

  // Header reveal
  const header = document.querySelector('.about-header');
  if (header) {
    gsap.from(header, {
      scrollTrigger: {
        trigger: '#about',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
    });
  }

  // Text paragraphs staggered reveal
  const paragraphs = document.querySelectorAll('.about-text p');
  paragraphs.forEach((p, i) => {
    gsap.from(p, {
      scrollTrigger: {
        trigger: p,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      y: 25,
      opacity: 0,
      duration: 0.6,
      delay: i * 0.15,
      ease: 'power3.out',
    });
  });
</script>
