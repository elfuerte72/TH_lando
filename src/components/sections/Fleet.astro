---
import { fleet } from '@/data/fleet';
---

<section id="fleet" class="relative py-20 lg:py-30 bg-dark overflow-hidden">
  <div class="max-w-[var(--container-max-width)] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header with truck image -->
    <div class="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8 mb-16 lg:mb-20">
      <div class="max-w-2xl relative z-10">
        <span class="fleet-label text-accent text-sm font-semibold uppercase tracking-widest inline-flex items-center gap-3">
          <span class="w-8 h-px bg-accent"></span>
          Техника
        </span>
        <h2 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black mt-4 mb-6 leading-[0.9]">
          <span class="fleet-title-line block overflow-hidden">
            <span class="inline-block">НАШ</span>
          </span>
          <span class="fleet-title-line block overflow-hidden">
            <span class="inline-block text-accent">АВТОПАРК</span>
          </span>
        </h2>
        <p class="fleet-subtitle text-gray-sub text-lg lg:text-xl leading-relaxed max-w-lg">
          <span class="text-white font-semibold">11 единиц</span> техники. Все — полный привод 6×6.
          Готовы к&nbsp;работе в&nbsp;любых условиях.
        </p>
      </div>

      <!-- Truck image — right side, blended into background -->
      <div class="hidden lg:block absolute -right-4 top-1/2 -translate-y-[45%] w-[650px] xl:w-[800px] h-[450px] xl:h-[500px] pointer-events-none">
        <img src="/images/fleet/fleet-bg.jpg" alt="" class="w-full h-full object-cover object-center scale-120" style="mask-image: radial-gradient(ellipse 70% 65% at 65% 50%, rgba(0,0,0,0.9) 25%, transparent 65%); -webkit-mask-image: radial-gradient(ellipse 70% 65% at 65% 50%, rgba(0,0,0,0.9) 25%, transparent 65%);" loading="lazy" />
      </div>
    </div>

    <!-- Fleet Grid — featured + grid layout -->
    <div class="fleet-grid grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mb-8">
      {fleet.slice(0, 2).map((vehicle, index) => (
        <article class="fleet-card group" data-index={index}>
          <div class="fleet-card-inner relative bg-card rounded-3xl overflow-hidden border border-white/5 h-full transition-all duration-500 hover:border-accent/40">
            <!-- Vehicle Image Area — tall for featured -->
            <div class="relative h-72 sm:h-80 lg:h-96 overflow-hidden bg-dark-lighter">
              <div class="absolute inset-0 bg-gradient-to-t from-card via-card/20 to-transparent z-10"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="relative">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-36 h-36 text-white/[0.06]" fill="currentColor" viewBox="0 0 640 512">
                    <path d="M48 0C21.5 0 0 21.5 0 48V368c0 26.5 21.5 48 48 48H64c0 53 43 96 96 96s96-43 96-96H384c0 53 43 96 96 96s96-43 96-96h32c17.7 0 32-14.3 32-32s-14.3-32-32-32V288 256 237.3c0-17-6.7-33.3-18.7-45.3L512 118.6c-12-12-28.3-18.7-45.3-18.7H416V48c0-26.5-21.5-48-48-48H48zM416 160h50.7L544 237.3V256H416V160zM208 416a48 48 0 1 1-96 0 48 48 0 1 1 96 0zm272 48a48 48 0 1 1 0-96 48 48 0 1 1 0 96z"/>
                  </svg>
                  <div class="absolute inset-0 blur-3xl bg-accent/10 rounded-full scale-150"></div>
                </div>
              </div>
              <!-- Badges -->
              {vehicle.type && (
                <div class="absolute top-5 left-5 z-20 bg-white/10 backdrop-blur-md text-white text-xs font-medium px-3 py-1.5 rounded-full border border-white/10">
                  {vehicle.type}
                </div>
              )}
              {vehicle.count > 1 && (
                <div class="absolute top-5 right-5 z-20 bg-accent text-white text-sm font-bold w-11 h-11 rounded-full flex items-center justify-center shadow-lg shadow-accent/30">
                  ×{vehicle.count}
                </div>
              )}
              <!-- Vehicle number watermark -->
              <div class="absolute bottom-2 right-6 z-20 text-[140px] font-black leading-none text-white/[0.03] select-none pointer-events-none">
                {String(index + 1).padStart(2, '0')}
              </div>
              <!-- Info overlay at bottom of image -->
              <div class="absolute bottom-0 left-0 right-0 z-20 p-6 lg:p-8">
                <h3 class="text-2xl lg:text-3xl font-bold text-white group-hover:text-accent transition-colors duration-300">{vehicle.name}</h3>
                <p class="text-gray-dim text-sm mt-1 flex items-center gap-2">
                  <span class="w-4 h-px bg-gray-dim"></span>
                  {vehicle.year}
                </p>
              </div>
            </div>
            <!-- Specs Row -->
            <div class="p-6 lg:p-8 pt-4 lg:pt-5">
              <div class="grid grid-cols-3 gap-3">
                <div class="bg-dark/60 rounded-2xl p-4 text-center border border-white/[0.03] hover:border-accent/20 transition-colors duration-300">
                  <div class="text-accent font-bold text-2xl lg:text-3xl">{vehicle.capacity}</div>
                  <div class="text-gray-dim text-xs mt-1 uppercase tracking-wider">тонн</div>
                </div>
                <div class="bg-dark/60 rounded-2xl p-4 text-center border border-white/[0.03] hover:border-accent/20 transition-colors duration-300">
                  <div class="text-accent font-bold text-2xl lg:text-3xl">{vehicle.volume}</div>
                  <div class="text-gray-dim text-xs mt-1 uppercase tracking-wider">м&sup3;</div>
                </div>
                <div class="bg-dark/60 rounded-2xl p-4 text-center border border-white/[0.03] hover:border-accent/20 transition-colors duration-300">
                  <div class="text-accent font-bold text-2xl lg:text-3xl">{vehicle.drive}</div>
                  <div class="text-gray-dim text-xs mt-1 uppercase tracking-wider">привод</div>
                </div>
              </div>
            </div>
            <!-- Accent line -->
            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-accent/50 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom 3 cards -->
    <div class="fleet-grid-bottom grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {fleet.slice(2).map((vehicle, index) => (
        <article class="fleet-card group" data-index={index + 2}>
          <div class="fleet-card-inner relative bg-card rounded-3xl overflow-hidden border border-white/5 h-full transition-all duration-500 hover:border-accent/40">
            <!-- Vehicle Image -->
            <div class="relative h-56 lg:h-64 overflow-hidden bg-dark-lighter">
              <div class="absolute inset-0 bg-gradient-to-t from-card via-card/20 to-transparent z-10"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="relative">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-28 h-28 text-white/[0.06]" fill="currentColor" viewBox="0 0 640 512">
                    <path d="M48 0C21.5 0 0 21.5 0 48V368c0 26.5 21.5 48 48 48H64c0 53 43 96 96 96s96-43 96-96H384c0 53 43 96 96 96s96-43 96-96h32c17.7 0 32-14.3 32-32s-14.3-32-32-32V288 256 237.3c0-17-6.7-33.3-18.7-45.3L512 118.6c-12-12-28.3-18.7-45.3-18.7H416V48c0-26.5-21.5-48-48-48H48zM416 160h50.7L544 237.3V256H416V160zM208 416a48 48 0 1 1-96 0 48 48 0 1 1 96 0zm272 48a48 48 0 1 1 0-96 48 48 0 1 1 0 96z"/>
                  </svg>
                  <div class="absolute inset-0 blur-3xl bg-accent/10 rounded-full scale-150"></div>
                </div>
              </div>
              {vehicle.type && (
                <div class="absolute top-5 left-5 z-20 bg-white/10 backdrop-blur-md text-white text-xs font-medium px-3 py-1.5 rounded-full border border-white/10">
                  {vehicle.type}
                </div>
              )}
              {vehicle.count > 1 && (
                <div class="absolute top-5 right-5 z-20 bg-accent text-white text-sm font-bold w-11 h-11 rounded-full flex items-center justify-center shadow-lg shadow-accent/30">
                  ×{vehicle.count}
                </div>
              )}
              <div class="absolute bottom-2 right-5 z-20 text-[100px] font-black leading-none text-white/[0.03] select-none pointer-events-none">
                {String(index + 3).padStart(2, '0')}
              </div>
              <!-- Info overlay -->
              <div class="absolute bottom-0 left-0 right-0 z-20 p-5 lg:p-6">
                <h3 class="text-xl lg:text-2xl font-bold text-white group-hover:text-accent transition-colors duration-300">{vehicle.name}</h3>
                <p class="text-gray-dim text-sm mt-1 flex items-center gap-2">
                  <span class="w-4 h-px bg-gray-dim"></span>
                  {vehicle.year}
                </p>
              </div>
            </div>
            <!-- Specs -->
            <div class="p-5 lg:p-6 pt-3 lg:pt-4">
              <div class="grid grid-cols-3 gap-2">
                <div class="bg-dark/60 rounded-xl p-3 text-center border border-white/[0.03] hover:border-accent/20 transition-colors duration-300">
                  <div class="text-accent font-bold text-xl lg:text-2xl">{vehicle.capacity}</div>
                  <div class="text-gray-dim text-xs mt-0.5 uppercase tracking-wider">тонн</div>
                </div>
                <div class="bg-dark/60 rounded-xl p-3 text-center border border-white/[0.03] hover:border-accent/20 transition-colors duration-300">
                  <div class="text-accent font-bold text-xl lg:text-2xl">{vehicle.volume}</div>
                  <div class="text-gray-dim text-xs mt-0.5 uppercase tracking-wider">м&sup3;</div>
                </div>
                <div class="bg-dark/60 rounded-xl p-3 text-center border border-white/[0.03] hover:border-accent/20 transition-colors duration-300">
                  <div class="text-accent font-bold text-xl lg:text-2xl">{vehicle.drive}</div>
                  <div class="text-gray-dim text-xs mt-0.5 uppercase tracking-wider">привод</div>
                </div>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-accent/50 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA Banner -->
    <div class="fleet-cta mt-12 lg:mt-16">
      <div class="relative bg-card rounded-3xl border border-white/5 overflow-hidden">
        <!-- Background glow -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-accent/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3"></div>
        <div class="relative flex flex-col sm:flex-row items-center justify-between gap-6 p-8 lg:p-12">
          <div>
            <h3 class="text-2xl lg:text-3xl font-bold text-white">Нужна техника?</h3>
            <p class="text-gray-sub mt-2">Подберём оптимальный вариант под ваш груз и&nbsp;маршрут</p>
          </div>
          <a href="#contact" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 cta-glow whitespace-nowrap flex-shrink-0">
            Оставить заявку
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 3D tilt perspective */
  .fleet-card {
    perspective: 1000px;
  }

  .fleet-card-inner {
    transform-style: preserve-3d;
    will-change: transform;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Title reveal ──
  gsap.from('.fleet-title-line > span', {
    y: '110%',
    duration: 1,
    ease: 'power4.out',
    stagger: 0.12,
    scrollTrigger: {
      trigger: '#fleet',
      start: 'top 75%',
    },
  });

  gsap.from('.fleet-label', {
    opacity: 0,
    x: -30,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: { trigger: '#fleet', start: 'top 75%' },
  });

  gsap.from('.fleet-subtitle', {
    opacity: 0,
    y: 20,
    duration: 0.8,
    delay: 0.3,
    ease: 'power3.out',
    scrollTrigger: { trigger: '#fleet', start: 'top 75%' },
  });


  // ── Staggered card reveals ──
  const topCards = document.querySelectorAll('.fleet-grid .fleet-card');
  gsap.from(topCards, {
    opacity: 0,
    y: 80,
    scale: 0.92,
    duration: 0.9,
    stagger: 0.15,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.fleet-grid',
      start: 'top 80%',
    },
  });

  const bottomCards = document.querySelectorAll('.fleet-grid-bottom .fleet-card');
  gsap.from(bottomCards, {
    opacity: 0,
    y: 80,
    scale: 0.92,
    duration: 0.9,
    stagger: 0.12,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.fleet-grid-bottom',
      start: 'top 85%',
    },
  });

  // ── CTA reveal ──
  gsap.from('.fleet-cta', {
    opacity: 0,
    y: 40,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.fleet-cta',
      start: 'top 90%',
    },
  });

  // ── 3D Card Tilt ──
  document.querySelectorAll('.fleet-card-inner').forEach((card) => {
    const el = card as HTMLElement;

    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -5;
      const rotateY = ((x - centerX) / centerX) * 5;

      gsap.to(el, {
        rotateX,
        rotateY,
        duration: 0.4,
        ease: 'power2.out',
        transformPerspective: 1000,
      });
    });

    el.addEventListener('mouseleave', () => {
      gsap.to(el, {
        rotateX: 0,
        rotateY: 0,
        duration: 0.6,
        ease: 'elastic.out(1, 0.5)',
      });
    });
  });

  // ── Counter animation ──
  const counters = document.querySelectorAll('.counter');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        gsap.to({ val: 0 }, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          onUpdate: function() {
            el.textContent = Math.round(this.targets()[0].val).toString();
          },
        });
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  counters.forEach(c => counterObserver.observe(c));
</script>
